# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_ADMIN_PASSWORD: optional, enables admin media editing UI locally.
# Example: VITE_ADMIN_PASSWORD="1234"
VITE_ADMIN_PASSWORD=""

# Supabase Postgres
# Copy from Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=""
DIRECT_URL=""

# Payments (Stripe)
# Use Stripe test keys for development; you can try the flow before the company is ready.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# iyzico / iyzipay (takvim kapora — Checkout Form; npm bu isimleri kullanır)
# Panel: "API Anahtarları" → sandbox- API + sandbox- güvenlik (Cep POS anahtarları bu akış için değil).
IYZIPAY_URI="https://sandbox-api.iyzipay.com"
IYZIPAY_API_KEY=""
IYZIPAY_SECRET_KEY=""
# İsteğe bağlı yedek: SANDBOX_API_KEY, SANDBOX_SECRET_KEY (kod otomatik okur)
# Ödeme dönüşü = API sunucusu kökü (.env PORT ile aynı port, örn. 3001 veya 3003)
API_PUBLIC_URL="http://127.0.0.1:3001"
# Ön yüz adresi (başarı yönlendirmesi); Vite varsayılanı 3000
APP_URL="http://127.0.0.1:3000"

# --- Vercel (aiag-rho.vercel.app gibi): aynı isimlerle Environment Variables ---
# IYZIPAY_URI / IYZIPAY_API_KEY / IYZIPAY_SECRET_KEY zorunlu. API_PUBLIC_URL ve APP_URL
# genelde https://<proje>.vercel.app (iyzico callback tam bu kök + /api/payments/iyzipay/return).
# Sandbox alıcı TC (üretimde gerçek kimlik toplanmalı)
IYZIPAY_DEFAULT_IDENTITY="74300864791"
IYZIPAY_DEFAULT_ADDRESS="Turkiye"

# Deposit config (minor units, e.g. TRY kuruş)
DEPOSIT_AMOUNT_MINOR="50000"
DEPOSIT_CURRENCY="try"
