# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where Ezgi Halı Perde is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_ADMIN_PASSWORD: optional, enables admin media editing UI locally.
# Example: VITE_ADMIN_PASSWORD="1234"
VITE_ADMIN_PASSWORD=""

# Supabase Postgres
# Copy from Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=""
DIRECT_URL=""

# Orders are handled through WhatsApp using the dynamic contact phone.
APP_URL="http://127.0.0.1:3000"
